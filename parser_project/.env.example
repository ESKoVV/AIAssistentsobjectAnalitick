VK_TOKEN=your_vk_token
VK_API_VERSION=5.131
VK_GROUP_DOMAINS=etorostovnadonu,rostov_glavniy,news161
VK_POSTS_PER_GROUP=100
VK_PAGE_SIZE=20
DAYS_BACK=7
RSS_FEEDS=https://example.com/rss,https://another.example/feed.xml

PORTAL_SOURCE=mock_local_file
PORTAL_APPEALS_FILE=portal_appeals.jsonl
MAX_MOCK_DATA_PATH=parser_project/mock/max_messages.json

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=raw.documents
KAFKA_GROUP_ID=documents-consumer-group

# Локальный доступ с хоста (внутри docker-compose consumer получит service-name postgres автоматически)
POSTGRES_DB=hack_db
POSTGRES_USER=hack_user
POSTGRES_PASSWORD=hack_pass
DATABASE_URL=postgresql://hack_user:hack_pass@localhost:5432/hack_db

FAILED_MESSAGES_PATH=failed_messages.jsonl
